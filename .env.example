# Задержки между запросами (секунды)
MIN_DELAY=3
MAX_DELAY=7

# Максимальное количество страниц для проверки
MAX_PAGES=5

# Товаров на странице Ozon
ITEMS_PER_PAGE=36

# Headless режим браузера (true/false)
HEADLESS=true

# Директория для результатов
RESULTS_DIR=results

# Директория для логов
LOGS_DIR=logs